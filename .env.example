# Database SQLite (base de données locale, aucun serveur requis)
# Pour PostgreSQL, utilisez: "postgresql://username:password@localhost:5432/friend_map?schema=public"
DATABASE_URL="file:./dev.db"

# Server
PORT=3000
NODE_ENV=development

# Google Maps API Key
# Obtenez votre clé API sur: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
